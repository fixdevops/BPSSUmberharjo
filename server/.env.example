# Salin file ini menjadi .env dan isi nilainya
# Jangan commit file .env ke git!

# Discord Bot
DISCORD_TOKEN=token_bot_discord_anda
CLIENT_ID=client_id_aplikasi_discord

# URL Deployment Vercel (untuk bot memanggil API)
API_BASE_URL=https://nama-project.vercel.app

# Secret bersama antara bot dan Vercel API (buat string acak panjang)
ADMIN_SECRET=ganti_dengan_string_acak_panjang_min_32_karakter

# Webhook Discord untuk notifikasi (sudah dikonfigurasi di Vercel env vars)
# WEBHOOK_URL dikonfigurasi langsung di Vercel Dashboard, bukan di sini
